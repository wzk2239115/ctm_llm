# CTM-Bind multimodal contrastive training.
# Runs the training script directly (no run_via_pool wrapper needed).

NODE_ADDRS=("127.0.0.1")
CLUSTER_NAME="ctm_bind_local"

NNODES=1
NODE_RANK=0
NPROC_PER_NODE=1
MASTER_ADDR=127.0.0.1
MASTER_PORT=29500

OMP_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false
NCCL_DEBUG=WARN

export TRAIN_ENTRY="scripts/run_via_pool.py"
export TRAIN_MODULE="baseline.tasks.multimodal_bind.train"

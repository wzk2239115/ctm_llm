# Multi-node template. Copy this file or override variables per node.
#
# Example for 2 nodes:
#   node0: NODE_RANK=0 MASTER_ADDR=<node0-ip> scripts/run_train.sh infra/envs/smoke_multinode.env
#   node1: NODE_RANK=1 MASTER_ADDR=<node0-ip> scripts/run_train.sh infra/envs/smoke_multinode.env
NNODES=2
NODE_RANK=0
NPROC_PER_NODE=8
MASTER_ADDR=10.0.0.1
MASTER_PORT=29500

OMP_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false

NCCL_DEBUG=WARN
NCCL_IB_DISABLE=0
NCCL_ASYNC_ERROR_HANDLING=1
TORCH_DISTRIBUTED_DEBUG=OFF

# Uncomment if NCCL chooses the wrong interface.
# NCCL_SOCKET_IFNAME=eth0

TRAIN_ARGS="\
  --epochs 1 \
  --batch_size 4 \
  --accumulation_steps 1 \
  --num_hidden_layers 4 \
  --hidden_size 512 \
  --d_model 256 \
  --d_input 128 \
  --heads 4 \
  --n_synch_out 256 \
  --n_synch_action 256 \
  --iterations 3 \
  --memory_length 5 \
  --synapse_depth 2 \
  --max_seq_len 256 \
  --log_interval 10 \
  --save_interval 200"

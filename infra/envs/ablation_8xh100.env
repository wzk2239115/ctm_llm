# Single-node 8xH100 ablation template.
# Override knobs at launch time, for example:
#   scripts/run_train.sh infra/envs/ablation_8xh100.env --cross_layer_state 0 --iterations 5
NNODES=1
NODE_RANK=0
NPROC_PER_NODE=8
MASTER_ADDR=127.0.0.1
MASTER_PORT=29501

OMP_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false

NCCL_DEBUG=WARN
NCCL_IB_DISABLE=0
NCCL_ASYNC_ERROR_HANDLING=1
TORCH_DISTRIBUTED_DEBUG=OFF

TRAIN_ARGS="\
  --epochs 1 \
  --batch_size 4 \
  --accumulation_steps 1 \
  --num_hidden_layers 8 \
  --hidden_size 512 \
  --d_model 256 \
  --d_input 128 \
  --heads 4 \
  --n_synch_out 256 \
  --n_synch_action 256 \
  --iterations 5 \
  --memory_length 5 \
  --synapse_depth 2 \
  --max_seq_len 256 \
  --log_interval 20 \
  --save_interval 500"

# Single-node 8xH100 smoke test.
NNODES=1
NODE_RANK=0
NPROC_PER_NODE=8
MASTER_ADDR=127.0.0.1
MASTER_PORT=29500

# Keep CPU threads conservative for data loading + torchrun workers.
OMP_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false

# NCCL defaults for H100 servers. Set NCCL_SOCKET_IFNAME if your cluster needs it.
NCCL_DEBUG=WARN
NCCL_IB_DISABLE=0
NCCL_ASYNC_ERROR_HANDLING=1
TORCH_DISTRIBUTED_DEBUG=OFF

TRAIN_ARGS="\
  --epochs 1 \
  --batch_size 4 \
  --accumulation_steps 1 \
  --num_hidden_layers 4 \
  --hidden_size 512 \
  --d_model 256 \
  --d_input 128 \
  --heads 4 \
  --n_synch_out 256 \
  --n_synch_action 256 \
  --iterations 3 \
  --memory_length 5 \
  --synapse_depth 2 \
  --max_seq_len 256 \
  --log_interval 10 \
  --save_interval 200"

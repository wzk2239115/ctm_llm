# Baseline CTM task execution on single node.
# This env file redirects the pool worker to run baseline tasks
# directly (python -m baseline.tasks.*) instead of through torchrun.
NNODES=1
NODE_RANK=0
NPROC_PER_NODE=1
MASTER_ADDR=127.0.0.1
MASTER_PORT=29500

OMP_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false
NCCL_DEBUG=WARN

# Override: use run_via_pool.sh to intercept and run baseline tasks
export TRAIN_ENTRY="scripts/run_via_pool.sh"

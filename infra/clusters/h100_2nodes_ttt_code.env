# Two-node CTM TTT-layer code-domain adaptation.
# Keep this file identical on every node.

CLUSTER_NAME=h100_2nodes_ttt_code
REPO_DIR=/home/jovyan/h800fast/wangzekai/ctm_llm

NODE_ADDRS=(
  11.131.210.78
  11.131.210.3
)

MASTER_PORT=29500
NPROC_PER_NODE=8

SSH_USER=root

GIT_REMOTE=origin
GIT_BRANCH=master
GIT_HTTP_PROXY=http://public-proxy.qihoo.net:3128
GIT_HTTPS_PROXY=http://public-proxy.qihoo.net:3128

SHARED_REPO=1

OMP_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false

NCCL_DEBUG=WARN
NCCL_IB_DISABLE=0
NCCL_ASYNC_ERROR_HANDLING=1
TORCH_DISTRIBUTED_DEBUG=OFF

# Use the streaming TTT-layer trainer instead of the standard SFT trainer.
TRAIN_ENTRY=train_ttt_stream.py

TRAIN_ARGS="\
  --from_weight out/ctm_2node_1024_16l_bs16_44ep_1024_resume.pth \
  --save_weight ctm_ttt_opc_code_1024 \
  --run_name ctm-ttt-opc-code-1024 \
  --dataset_name OpenCoder-LLM/opc-annealing-corpus \
  --dataset_path dataset/opc-annealing-corpus \
  --dataset_config algorithmic_corpus \
  --dataset_split train \
  --text_field text \
  --max_steps 1000 \
  --batch_size 4 \
  --accumulation_steps 1 \
  --learning_rate 1e-5 \
  --max_seq_len 512 \
  --hidden_size 1024 \
  --num_hidden_layers 16 \
  --d_model 512 \
  --d_input 256 \
  --heads 8 \
  --n_synch_out 512 \
  --n_synch_action 512 \
  --iterations 4 \
  --memory_length 5 \
  --synapse_depth 2 \
  --ttt_target ttt_layers \
  --ttt_hidden_mult 2 \
  --ttt_gate_init -2.0 \
  --num_iters 4 \
  --ddp_timeout_minutes 60 \
  --log_interval 20 \
  --save_interval 500"

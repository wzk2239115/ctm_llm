# Two-node H100 cluster.
# Keep this file identical on every node.

CLUSTER_NAME=h100_2nodes
REPO_DIR=/home/jovyan/h800fast/wangzekai/ctm_llm

# The first node is used as torchrun MASTER_ADDR.
NODE_ADDRS=(
  11.131.210.78
  11.131.210.3
)

MASTER_PORT=29500
NPROC_PER_NODE=8

# Optional. Set this if SSH needs a user prefix, for example SSH_USER=root.
SSH_USER=root

OMP_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false

NCCL_DEBUG=WARN
NCCL_IB_DISABLE=0
NCCL_ASYNC_ERROR_HANDLING=1
TORCH_DISTRIBUTED_DEBUG=OFF

# Uncomment if NCCL picks the wrong network interface.
# NCCL_SOCKET_IFNAME=eth0

TRAIN_ARGS="\
  --epochs 1 \
  --batch_size 4 \
  --accumulation_steps 1 \
  --num_hidden_layers 4 \
  --hidden_size 512 \
  --d_model 256 \
  --d_input 128 \
  --heads 4 \
  --n_synch_out 256 \
  --n_synch_action 256 \
  --iterations 3 \
  --memory_length 5 \
  --synapse_depth 2 \
  --max_seq_len 256 \
  --log_interval 10 \
  --save_interval 200"

#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  scripts/ctmctl <command> [args...]

Commands:
  pool server [args...]          Start no-SSH pool server
  pool worker [CONFIG] [args...] Start worker, auto rank, auto-pull before tasks
  pool submit [CONFIG] [args...] Submit task to pool
  pool status [args...]          Show pool status JSON
  train cluster --config CONFIG  Start cluster torchrun with auto rank
  train env ENV_FILE [args...]   Start torchrun from env file
  check [ENV_FILE]               Run cluster preflight checks

Examples:
  scripts/ctmctl pool server
  scripts/ctmctl pool worker infra/clusters/h100_2nodes.env
  scripts/ctmctl pool submit infra/clusters/h100_2nodes.env --iterations 5
  scripts/ctmctl train cluster --config infra/clusters/h100_2nodes.env
  scripts/ctmctl check infra/envs/smoke_8xh100.env
EOF
}

if [[ $# -lt 1 || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

cmd="$1"
shift

case "$cmd" in
  pool)
    sub="${1:-}"
    if [[ -z "$sub" ]]; then
      usage >&2
      exit 1
    fi
    shift
    case "$sub" in
      server)
        exec python scripts/cluster_pool.py server "$@"
        ;;
      worker)
        config="infra/clusters/h100_2nodes.env"
        if [[ $# -gt 0 && "${1:0:1}" != "-" ]]; then
          config="$1"
          shift
        fi
        exec python scripts/cluster_pool.py worker --config "$config" "$@"
        ;;
      submit)
        config="infra/clusters/h100_2nodes.env"
        if [[ $# -gt 0 && "${1:0:1}" != "-" ]]; then
          config="$1"
          shift
        fi
        if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
          exec python scripts/cluster_pool.py submit --config "$config" "$1"
        fi
        train_args=()
        cmd_args=(python scripts/cluster_pool.py submit --config "$config")
        while [[ $# -gt 0 ]]; do
          case "$1" in
            --master_addr|--port|--wait|--nodes)
              cmd_args+=("$1" "${2:-}")
              shift 2
              ;;
            --)
              shift
              train_args+=("$@")
              break
              ;;
            *)
              train_args+=("$1")
              shift
              ;;
          esac
        done
        cmd_args+=(-- "${train_args[@]}")
        exec "${cmd_args[@]}"
        ;;
      status)
        exec python scripts/cluster_pool.py status "$@"
        ;;
      *)
        echo "Unknown pool command: $sub" >&2
        usage >&2
        exit 1
        ;;
    esac
    ;;
  train)
    sub="${1:-}"
    if [[ -z "$sub" ]]; then
      usage >&2
      exit 1
    fi
    shift
    case "$sub" in
      cluster)
        exec bash scripts/train_cluster.sh "$@"
        ;;
      env)
        env_file="${1:-infra/envs/smoke_8xh100.env}"
        if [[ $# -gt 0 ]]; then
          shift
        fi
        exec bash scripts/run_train.sh "$env_file" "$@"
        ;;
      *)
        echo "Unknown train command: $sub" >&2
        usage >&2
        exit 1
        ;;
    esac
    ;;
  check)
    env_file="${1:-infra/envs/smoke_8xh100.env}"
    exec bash scripts/check_cluster.sh "$env_file"
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    usage >&2
    exit 1
    ;;
esac
